{
  // Deploy de Aulirex como sitio estático en Cloudflare (Workers Static Assets).
  // `npm run build` genera ./dist y `npx wrangler deploy` lo publica.
  "name": "aulirex",
  "compatibility_date": "2025-01-01",
  "assets": {
    // Sirve el SPA; para rutas desconocidas devuelve index.html (aunque usamos
    // HashRouter, esto cubre cualquier acceso directo).
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
